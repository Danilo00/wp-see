# Storage cloud (Vercel / produzione)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/wp-see
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_S3_BUCKET=your-bucket-name

# auto = cloud se Mongo+S3 configurati, altrimenti locale
STORAGE_MODE=auto

# Fallback locale (dev senza cloud)
CHATS_ROOT=./chats

# Debug
DEBUG_ENABLE=false
DEBUG_LEVEL=4

# Opzionale: proteggi POST /api/chats/migrate-local
MIGRATE_SECRET=
